{
  "name": "school-management-crm-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "cross-env RUN_LIVE_API_TESTS=1 vitest run --config vitest.live.config.js",
    "test:smoke": "node src/scripts/smoke-test-apis.js",
    "db:setup": "node src/scripts/setup-database.js",
    "db:reset": "cross-env DB_RESET=true node src/scripts/setup-database.js",
    "db:seed": "node src/scripts/seed-sample-data.js",
    "db:seed-passwords": "node src/scripts/seed-passwords.js",
    "db:reset-admin": "node src/scripts/seed-passwords.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "supertest": "^7.0.0",
    "vitest": "^2.1.2"
  }
}
