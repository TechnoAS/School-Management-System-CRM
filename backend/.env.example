# Backend (Node.js + Express + MySQL) — copy to backend/.env
# See SECURITY.md for secrets management details

# ─────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────
# Database (MySQL / MariaDB)
# ─────────────────────────────────────────────────────────────────
# Connection string: mysql://USER:PASSWORD@HOST:PORT/DBNAME
# Note: Use a dedicated restricted DB user in production (see SECURITY.md)
DATABASE_URL=mysql://crm_app:CHANGE_ME@localhost:3306/techacademy_crm
DATABASE_POOL_MAX=10

# ─────────────────────────────────────────────────────────────────
# JWT — Generate each with: openssl rand -hex 64
# ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=GENERATE_WITH_openssl_rand_hex_64
JWT_REFRESH_SECRET=GENERATE_SEPARATE_SECRET_WITH_openssl_rand_hex_64

# Access token: 15 minutes limit (production best practice)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token: HttpOnly cookie
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────
# Password Hashing
# ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────
# Exact URL of your client frontend
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────
# Limit for login/auth endpoints per 15 minutes per IP
RATE_LIMIT_AUTH_MAX=5
# General request limits per minute per IP
RATE_LIMIT_API_MAX=120

# ─────────────────────────────────────────────────────────────────
# File Uploads (Multer)
# ─────────────────────────────────────────────────────────────────
# Absolute path outside server static folders
UPLOAD_DIR=/var/data/crm-uploads
MAX_UPLOAD_MB=5
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ─────────────────────────────────────────────────────────────────
# Transactional Email (Password resets & updates)
# ─────────────────────────────────────────────────────────────────
# Brevo (formerly Sendinblue) provides 300 free emails/day.
# Gmail SMTP or local postfix are other free solutions.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM="School CRM" <no-reply@yourdomain.com>

# ─────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
